# NoMan CLI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the filled .env to version control.

# Anthropic API key (required for claude provider)
ANTHROPIC_API_KEY=

# OpenAI API key (required for openai provider)
OPENAI_API_KEY=

# Enable debug logging
NOMAN_DEBUG=0

# Emergency stop flag — set to "1" to halt all agent operations
NOMAN_EMERGENCY_STOP=0

# Optional: base URL for OpenAI-compatible providers (Ollama, Groq, Azure, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1

# Optional: custom model overrides per provider
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o
